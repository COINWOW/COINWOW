src/clientversion.cpp export-subst

# Normalize all text files to LF line endings in the repository.
* text=auto eol=lf

# Explicitly declare binary files to prevent normalization.
*.png binary
*.ico binary
*.icns binary
*.bmp binary
*.gif binary
*.jpg binary
*.jpeg binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.bz2 binary
*.xz binary
*.zst binary
*.7z binary
*.tar binary
*.tgz binary
*.a binary
*.o binary
*.so binary
*.dll binary
*.exe binary
*.dylib binary
*.lib binary

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
